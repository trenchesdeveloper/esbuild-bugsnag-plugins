{
  "name": "esbuild-bugsnag-plugins",
  "version": "1.3.0",
  "description": "esbuild plugins for uploading Bugsnag source maps and reporting builds",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "version-packages": "changeset version",
    "release": "npm publish --access public"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "esbuild": ">=0.19.0"
  },
  "dependencies": {
    "@bugsnag/source-maps": "^2.3.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.17.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "esbuild",
    "bugsnag",
    "plugin",
    "sourcemap",
    "source-map",
    "build",
    "typescript"
  ],
  "author": "trenchesdeveloper",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trenchesdeveloper/esbuild-bugsnag-plugins.git"
  },
  "bugs": {
    "url": "https://github.com/trenchesdeveloper/esbuild-bugsnag-plugins/issues"
  },
  "homepage": "https://github.com/trenchesdeveloper/esbuild-bugsnag-plugins#readme"
}
